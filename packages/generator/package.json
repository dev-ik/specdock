{
  "name": "@specdock/generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests --exclude='dist/**'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@specdock/core": "0.1.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
